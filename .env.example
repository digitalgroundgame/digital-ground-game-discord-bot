DISCORD_CLIENT_ID="id"
DISCORD_BOT_TOKEN="token"
DISCORD_BOT_DEVELOPER_IDS="123456789012345678"
DISCORD_GUILD_ID="guild_id"

# Postgres connection (matches docker-compose.yml defaults for local dev)
DATABASE_URL="postgres://dggac:dggac@localhost:5432/dggac"

# optional: hourly sync of Discord scheduled events → DGGP Google Calendar (service account)
# GOOGLE_CALENDAR_ID="your-calendar-id@group.calendar.google.com"
# GOOGLE_APPLICATION_CREDENTIALS="path/to/service-account.json"
#   (or GOOGLE_CALENDAR_CREDENTIALS — same idea; share the calendar with the service account email)
# Optional: only if you use Google Workspace domain-wide delegation (otherwise omit):
# GOOGLE_CALENDAR_IMPERSONATION_SUBJECT="user@yourdomain.org"

# optional / unused
DISCORD_BOT_MASTER_API_TOKEN="test-passing-var"
DISCORD_BOT_API_SECRET="test-passing-var"
