DISCORD_CLIENT_ID="id"
DISCORD_BOT_TOKEN="token"
DISCORD_BOT_DEVELOPER_IDS="123456789012345678"

# optional: sync Discord scheduled events to DGGP Google Calendar
# GOOGLE_CALENDAR_ID="your-calendar-id@group.calendar.google.com"
#
# Option A — Service account JSON (share calendar with the service account email):
# GOOGLE_APPLICATION_CREDENTIALS="path/to/service-account.json"
#
# Option B — OAuth 2.0 client JSON ("Download JSON" on your OAuth client in Google Cloud):
# GOOGLE_CALENDAR_CREDENTIALS="path/to/client_secret_....json"
# Then run once: npm run calendar:oauth  (writes config/google-calendar-oauth-tokens.json)
# GOOGLE_CALENDAR_OAUTH_TOKEN_PATH="config/google-calendar-oauth-tokens.json"
# GOOGLE_OAUTH_REDIRECT_URI="http://127.0.0.1:34567/oauth2callback"  # must match GCP Authorized redirect URIs

# optional / unused
# DISCORD_BOT_MASTER_API_TOKEN="token"
# DISCORD_BOT_API_SECRET="secret"
