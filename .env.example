DISCORD_CLIENT_ID="id"
DISCORD_BOT_TOKEN="token"
DISCORD_BOT_DEVELOPER_IDS="123456789012345678"

# SQLite database file path (relative or absolute)
SQLITE_PATH="./data/dggac.sqlite"

# CRM integration: required for /attendance-track to post staged attendance.
# Local dev: point at the in-house-mgmt server (default port 8080) and a token
# created in Django admin → Auth → Tokens for a user in the DISCORD_BOT group.
CRM_API_URL="http://localhost:8080"
CRM_API_TOKEN="paste-token-from-django-admin"

# optional: hourly sync of Discord scheduled events → DGG Google Calendar (service account)
# GOOGLE_CALENDAR_ID="your-calendar-id@group.calendar.google.com"
# GOOGLE_APPLICATION_CREDENTIALS="path/to/service-account.json"
#   (or GOOGLE_CALENDAR_CREDENTIALS — same idea; share the calendar with the service account email)
# Optional: only if you use Google Workspace domain-wide delegation (otherwise omit):
# GOOGLE_CALENDAR_IMPERSONATION_SUBJECT="user@yourdomain.org"

# optional: /group-add command — add Discord members to Google Groups.
# Workspace admin the service account impersonates to manage group membership
# (requires domain-wide delegation with the admin.directory.group.member scope):
# GOOGLE_WORKSPACE_ADMIN_SUBJECT="admin@yourdomain.org"
# Reuses GOOGLE_APPLICATION_CREDENTIALS / GOOGLE_CALENDAR_CREDENTIALS for the service account key.

# optional / unused
DISCORD_BOT_MASTER_API_TOKEN="test-passing-var"
DISCORD_BOT_API_SECRET="test-passing-var"
