{
  "name": "dggac-bot",
  "version": "1.0.0",
  "author": "DGG AC Dev Team",
  "description": "A discord.js bot for DGGAC discord server",
  "license": "MIT",
  "private": true,
  "type": "module",
  "exports": [
    "./dist/start-bot.js",
    "./dist/start-manager.js"
  ],
  "scripts": {
    "lint": "eslint . --cache --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --fix --cache --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "clean": "git clean -xdf --exclude=\"/config/**/*\"",
    "clean:dry": "git clean -xdf --exclude=\"/config/**/*\" --dry-run",
    "check-node-version": "node scripts/check-node-version.mjs",
    "build": "tsc --project tsconfig.json",
    "docker:build": "docker build .",
    "preinstall": "node scripts/check-node-version.mjs",
    "calendar:sync": "npm run build && node --enable-source-maps dist/start-bot.js calendar sync",
    "backup:sqlite": "node --enable-source-maps dist/backup-sqlite.js",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "start": "npm run start:bot",
    "start:bot": "npm run build && node --enable-source-maps dist/start-bot.js",
    "start:manager": "npm run build && node --enable-source-maps dist/start-manager.js",
    "start:pm2": "npm run build && npm run pm2:start",
    "pm2:start": "pm2 start process.json",
    "pm2:stop": "pm2 stop process.json",
    "pm2:delete": "pm2 delete process.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check-types": "tsc --noEmit",
    "copyconfig": "cp config/debug.example.json config/debug.json && cp config/bot-sites.example.json config/bot-sites.json  && cp .env.example .env"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1082.0",
    "@discordjs/rest": "^2.5.1",
    "better-sqlite3": "^12.10.0",
    "canvas": "^3.2.0",
    "chart.js": "^4.5.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "cron-parser": "^5.3.0",
    "discord.js": "^14.21.0",
    "discord.js-rate-limiter": "1.3.2",
    "dotenv": "^17.2.0",
    "drizzle-orm": "^0.45.2",
    "express": "5.2.1",
    "filesize": "10.1.6",
    "googleapis": "^171.4.0",
    "linguini": "1.3.1",
    "luxon": "3.6.1",
    "node-fetch": "3.3.2",
    "node-schedule": "2.1.1",
    "pino": "9.7.0",
    "pino-pretty": "13.0.0",
    "pm2": "^7.0.1",
    "reflect-metadata": "^0.2.2",
    "remove-markdown": "0.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "5.0.6",
    "@types/luxon": "3.6.2",
    "@types/node": "^24.12.4",
    "@types/node-schedule": "2.1.7",
    "@types/remove-markdown": "0.3.4",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.30.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^62.0.0",
    "prettier": "^3.6.2",
    "supertest": "^7.2.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "esbuild": "0.25.12",
    "js-yaml": "4.2.0",
    "pm2": {
      "ws": "8.21.0"
    }
  }
}
